# ─── App ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
SERVICE_NAME=gocomet-api
LOG_LEVEL=info

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=gocomet
DB_PASSWORD=gocomet_dev
DB_NAME=gocomet_rides
DB_SYNC=false
DB_LOGGING=true

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:19092
KAFKA_CLIENT_ID=gocomet-api
KAFKA_GROUP_ID=gocomet-consumers

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-min-32-chars!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars!
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# 10 = OWASP minimum, industry standard for high-throughput APIs (~65ms). Raise to 12 only for low-traffic systems.
BCRYPT_ROUNDS=10
COOKIE_SECURE=false

# ─── New Relic ────────────────────────────────────────────────────────────────
NEW_RELIC_LICENSE_KEY=
NEW_RELIC_APP_NAME=gocomet-rides-dev
NEW_RELIC_ENABLED=false
